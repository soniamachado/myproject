generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Band {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  status      Status   @default(active)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  coverUrl    String   @default("uploads/default.jpg")
  tracks      Tracks[] @relation("BandTracks")

  @@map("bands")
}

model Tracks {
  id               String   @id @default(uuid()) @db.Uuid
  title            String
  slug             String   @unique
  durationInSecond Int      @map("duration_in_second")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  bandId           String   @map("band_id") @db.Uuid
  coverUrl         String   @default("uploads/default.jpg")
  band             Band     @relation("BandTracks", fields: [bandId], references: [id], onDelete: Cascade)

  @@index([bandId])
  @@map("tracks")
}

enum Status {
  active
  inactive
}
